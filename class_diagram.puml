@startuml
skinparam classAttributeIconSize 0
left to right direction

package "Client" {
  class MailClient {
    -clientId: String
    +login(email, password)
    +searchMail(keyword)
    +openEmail(emailId)
    +correctCategory(emailId, categoryId)
  }
}

package "Core Services" {
  class MailServer {
    -serverId: String
    +receiveEmail(rawMail)
    +storeEmail(email)
    +sendForAnalysis(email)
  }

  class EmailPreprocessor {
    +extractData(rawMail): Email
    +cleanContent(email): Email
    +normalizeMetadata(email): Email
  }

  class MailboxOrganizer {
    +assignMailbox(email, category)
    +moveToUncategorized(email)
  }

  class LLMModule {
    +classifyEmail(email, profile): Category
    +scorePriority(email, profile): int
    +suggestActions(email, profile): SuggestedAction[*]
  }

  class HallucinationMitigator {
    +validateOutput(email, output): boolean
    +reprocessInvalidOutput(output)
  }

  interface ExternalMailService {
    +fetchIncomingMail()
    +sendMail(email)
  }
}

package "Domain" {
  class User {
    -userId: String
    -emailAddress: String
    +login()
    +logout()
    +updateProfile()
  }

  class UserProfile {
    -userType: UserType
    -interests: String[*]
    -affiliations: String[*]
    +editProfile()
  }

  class ImportantContact {
    -contactEmail: String
    -name: String
  }

  abstract class Mailbox {
    -mailboxId: String
    -name: String
    +addEmail(email)
    +removeEmail(email)
  }

  class AllMailbox
  class CategoryMailbox
  class UncategorizedMailbox

  abstract class Category {
    -categoryId: String
    -label: String
  }

  class PredefinedCategory
  class CustomCategory

  class Email {
    -emailId: String
    -sender: String
    -receiver: String
    -subject: String
    -body: Text
    -receivedAt: DateTime
  }

  class Attachment {
    -fileName: String
    -mimeType: String
    -size: long
  }

  class EmailAnalysis {
    -priorityScore: int
    -validated: boolean
    +updateResult()
  }

  abstract class SuggestedAction {
    -actionName: String
    -reason: String
  }

  class StandardAction
  class CustomAction

  class CorrectionRecord {
    -correctedAt: DateTime
    -oldCategory: String
    -newCategory: String
  }

  enum UserType {
    Student
    Professor
    Worker
    Alumni
    Guest
  }
}

Mailbox <|-- AllMailbox
Mailbox <|-- CategoryMailbox
Mailbox <|-- UncategorizedMailbox

Category <|-- PredefinedCategory
Category <|-- CustomCategory

SuggestedAction <|-- StandardAction
SuggestedAction <|-- CustomAction

User "1" *-- "1" UserProfile : owns
User "1" *-- "1" AllMailbox : has
User "1" *-- "0..*" CategoryMailbox : creates
User "1" *-- "1" UncategorizedMailbox : has
UserProfile "1" *-- "0..*" ImportantContact : contains
AllMailbox "1" *-- "0..*" Email : stores
Email "1" *-- "0..*" Attachment : contains
Email "1" *-- "0..1" EmailAnalysis : has
EmailAnalysis "1" *-- "0..*" SuggestedAction : recommends

CategoryMailbox "1" o-- "1" Category : represents
User "1" o-- "0..*" CorrectionRecord : submits

MailClient "1" -- "1" User : usedBy
MailClient "1" -- "1" MailServer : sends requests to
MailServer "1" --> "1" EmailPreprocessor : preprocesses with
MailServer "1" --> "1" LLMModule : requests analysis from
MailServer "1" --> "1" MailboxOrganizer : organizes with
MailServer "1" ..> "1" ExternalMailService : uses
LLMModule "1" --> "1" HallucinationMitigator : validates with
LLMModule "1" --> "0..*" Email : analyzes
LLMModule "1" --> "1" UserProfile : reads
MailboxOrganizer "1" --> "0..*" CategoryMailbox : assigns to
MailboxOrganizer "1" --> "1" UncategorizedMailbox : fallback to
CategoryMailbox "0..1" -- "0..*" Email : classifiedIn
UncategorizedMailbox "0..1" -- "0..*" Email : holds
CorrectionRecord "1" --> "1" EmailAnalysis : updates
CorrectionRecord "1" --> "1" Email : corrects

@enduml
